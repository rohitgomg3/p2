{
  "name": "plakshabudget",
  "version": "1.0.0",
  "description": "PlakshaBudget full stack app - React + Node/Express + MySQL",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "frontend": "vite --host localhost",
    "frontend:dev": "vite --host localhost",
    "dev": "concurrently \"npm run server:dev\" \"npm run frontend:dev\"",
    "db:init": "node scripts/init-mysql.js",
    "admin:reset": "node scripts/reset-admin-password.js",
    "build": "vite build",
    "preview": "vite preview --host localhost"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.4",
    "nodemailer": "^8.0.9",
    "pg": "^8.11.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.0",
    "vite": "^7.2.4"
  }
}
