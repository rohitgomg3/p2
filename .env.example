# Copy this file to .env and fill in your values

# Server
PORT=4000
JWT_SECRET=change_this_to_a_long_random_secret_string
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# PostgreSQL (default)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=budgetflow
DB_USER=postgres
DB_PASS=yourpassword
DB_SSL=false

# MySQL (alternative — also install: npm install mysql2)
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=budgetflow
# DB_USER=root
# DB_PASS=yourpassword

# SMTP Config
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@budgetflow.com

# Microsoft SSO (Optional - if client ID is left blank, simulated SSO mode is active)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/microsoft/callback
# FRONTEND_URL=http://localhost:5174
# VITE_API_URL=http://localhost:4000

# Microsoft Teams Webhook for Notifications (Optional)
# TEAMS_WEBHOOK_URL=

# Microsoft Teams Native Approvals App Integration (Optional)
# TEAMS_APPROVAL_FLOW_URL=
# TEAMS_CALLBACK_KEY=teams_approval_secret_key_change_in_prod



